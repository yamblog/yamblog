{
  "name": "yamblog",
  "private": false,
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "website",
    "examples/*"
  ],
  "scripts": {
    "validate:content": "bun run scripts/validate-content.ts",
    "build": "bun run validate:content && bun run --filter './packages/*' build",
    "build:changed": "bun run validate:content && node scripts/build-changed.mjs",
    "test": "bun run --filter './packages/*' test",
    "typecheck": "bun run --filter './packages/*' typecheck",
    "lint": "bun run --filter './packages/*' lint",
    "dev:website": "bun run --filter website dev",
    "example:next": "bun run --filter with-nextjs dev",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "25.6.2",
    "typescript": "6.0.3"
  }
}
