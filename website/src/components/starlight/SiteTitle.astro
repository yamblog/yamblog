---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" aria-label="YAMBlog home">
  <span class="brand-mark" aria-hidden="true">Y</span>
  <span class="brand-name" translate="no">YAMBlog<em> /yamblog/</em></span>
</a>

<style>
  @layer starlight.core {
    .site-title {
      align-items: center;
      gap: 0.625rem;
      color: var(--sl-color-text);
      text-decoration: none;
      white-space: nowrap;
      min-width: 0;
    }

    .brand-mark {
      width: 1.625rem;
      height: 1.625rem;
      border-radius: 0.4375rem;
      background: var(--sl-color-text);
      color: var(--sl-color-bg);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: -0.02em;
      position: relative;
      flex: none;
    }

    .brand-mark::after {
      content: '';
      position: absolute;
      right: -0.125rem;
      bottom: -0.125rem;
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 0.125rem;
      background: var(--sl-color-accent);
      border: 2px solid var(--sl-color-bg);
    }

    .brand-name {
      overflow: hidden;
      font-size: 0.90625rem;
      font-weight: 600;
      letter-spacing: -0.005em;
      color: var(--sl-color-text);
    }

    .brand-name em {
      font-family: 'Newsreader', ui-serif, Georgia, serif;
      font-style: italic;
      font-weight: 500;
      color: var(--sl-color-text-secondary);
    }
  }
</style>
