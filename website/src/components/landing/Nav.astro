---
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/">
      <span class="brand-mark">Y</span>
      <span class="brand-name">YAMBlog<em> /yamblog/</em></span>
    </a>

    <nav class="nav-links">
      <a href="#features">Features</a>
      <a href="#packages">Packages</a>
      <a href="#agents">Agents</a>
      <a href="/getting-started/">Docs</a>
      <a href="/blog">Blog</a>
    </nav>

    <div class="nav-actions">
      <button class="icon-btn" aria-label="Toggle theme" data-theme-toggle>
        <!-- Sun (shown in dark mode) -->
        <svg class="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <!-- Moon (shown in light mode) -->
        <svg class="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a class="gh-btn" href="https://github.com/yamblog/yamblog" aria-label="GitHub" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.37-3.87-1.37-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18A11.05 11.05 0 0 1 12 6.8c.98 0 1.97.13 2.9.39 2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.19 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>

<style>
  /* Sun/moon toggle — show correct icon per theme */
  [data-theme="dark"] .icon-moon  { display: none; }
  [data-theme="light"] .icon-sun  { display: none; }
  /* Default before JS (dark) */
  :root:not([data-theme="light"]) .icon-moon { display: none; }
</style>
