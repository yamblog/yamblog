---
const features = [
  {
    num: '01',
    label: 'File-based',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="1.5" width="8" height="9" rx="1"/><path d="M4 4.5h4M4 6.5h4M4 8.5h2.5"/></svg>`,
    title: 'No database. No CMS. No lock-in.',
    body: 'Markdown files in a directory. Frontmatter as schema. Move providers, fork the repo, hand it to an LLM — your content goes with you.',
    meta: ['.md files', 'frontmatter', 'git-native'],
  },
  {
    num: '02',
    label: 'Type-safe',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 3.5l4 5 4-5M6 8.5v2"/></svg>`,
    title: 'Zod schemas, end to end.',
    body: 'Define frontmatter once and get full TypeScript inference across every query, metadata helper, and adapter. Mistypes fail at build, not in production.',
    meta: ['zod', 'strict mode', 'inferred types'],
  },
  {
    num: '03',
    label: 'Framework-agnostic',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><path d="M4 1.5v3M8 1.5v3M3 4.5h6v3a3 3 0 0 1-6 0v-3zM6 10.5v1"/></svg>`,
    title: 'Pure core. Thin adapters.',
    body: 'All business logic lives in @yamblog/core. Adapters for Next.js, Astro, and React are thin wrappers — switch frameworks without rewriting your blog.',
    meta: ['next.js', 'astro', 'react'],
  },
  {
    num: '04',
    label: 'Zero-config defaults',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"><path d="M7 1.5L3 7h2.5L5 10.5 9 5H6.5L7 1.5z"/></svg>`,
    title: 'Sensible from the first commit.',
    body: 'defineBlog() with no args just works. Site URL is auto-detected from env vars. Reading time, draft filtering, related posts, full-text search — all on by default.',
    meta: ['defineBlog()', 'env auto-detect', '200 wpm'],
  },
  {
    num: '05',
    label: 'SEO-ready',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"><circle cx="3" cy="9" r=".8" fill="currentColor"/><path d="M2.5 6.5a3 3 0 0 1 3 3M2.5 3a6.5 6.5 0 0 1 6.5 6.5"/></svg>`,
    title: "SEO that doesn't need a checklist.",
    body: 'JSON-LD Article schema, OpenGraph, Twitter cards, canonical URLs, RSS 2.0, and a sitemap — generated automatically from the same posts you already wrote.',
    meta: ['schema.org', 'rss', 'sitemap'],
  },
  {
    num: '06',
    label: 'Agentic-first',
    glyph: `<svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="3.5" width="8" height="6" rx="1"/><path d="M6 1.5v2"/><circle cx="4.5" cy="6.5" r=".4" fill="currentColor"/><circle cx="7.5" cy="6.5" r=".4" fill="currentColor"/></svg>`,
    title: 'An API your AI agent can hold.',
    body: 'Stable blog-{slug} IDs as foreign keys, Zod-validated frontmatter, predictable file layout. Drop the setup prompt into Claude Code and walk away.',
    meta: ['stable ids', 'zod validation', 'setup prompt'],
  },
];
---

<section id="features" class="section">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="section-eyebrow">Why Yamblog</div>
        <h2 class="section-title">Six choices, made <em>once,</em> made well.</h2>
      </div>
      <p class="section-lead">
        Every product needs a blog. Contentlayer is dead. Astro Collections are Astro-only.
        Next.js starters are copy-paste nightmares. Yamblog is the missing middle.
      </p>
    </div>

    <div class="features">
      {features.map(f => (
        <div class="feature">
          <div class="feature-num">
            <span class="glyph"><Fragment set:html={f.glyph} /></span>
            {f.num} / {f.label}
          </div>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
          <div class="feature-meta">
            {f.meta.map(tag => <span>{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
