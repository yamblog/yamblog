---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Yamblog + Astro Example">
  <main style="max-width: 640px; margin: 0 auto; padding: 4rem 1rem;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Yamblog + Astro</h1>
    <p style="color: #71717a; margin-bottom: 2rem;">
      A working example of <strong>@yamblog/astro</strong> — file-based blogging with the Astro Content Layer API.
    </p>
    <a
      href="/blog"
      style="display: inline-block; background: #18181b; color: #fff; padding: 0.5rem 1.25rem; border-radius: 6px; text-decoration: none;"
    >
      View Blog &rarr;
    </a>
  </main>
</Layout>
