{
  "name": "@yamblog/core",
  "version": "2.0.0",
  "description": "Framework-agnostic markdown blog engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    }
  },
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "rm -rf ./dist && tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.typetest.json",
    "lint": "eslint src/"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.0"
  },
  "keywords": [
    "blog",
    "markdown",
    "cms",
    "yamblog"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yamblog/yamblog.git",
    "directory": "packages/core"
  },
  "homepage": "https://yamblog.dev",
  "bugs": "https://github.com/yamblog/yamblog/issues",
  "author": "Bharat Parsiya (https://bnap.dev)"
}
